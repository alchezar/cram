# cram server config. Run from the project root; paths are relative to it.
# Copy this file to cram.toml and adjust for your machine.
port         = 16666
web_dir      = "web"
quizzes_dir  = "quizzes"
roadmap_file = "roadmap.toml"

# Optional. When omitted, the database is created under the platform data dir:
#   macOS    ~/Library/Application Support/cram/cram.db
#   Linux    ~/.local/share/cram/cram.db
#   Windows  %APPDATA%\cram\cram.db
# Set it only to override that location; `?mode=rwc` creates the file if missing.
# database_url = "sqlite:/absolute/path/to/cram.db?mode=rwc"
